# Copy this file to `.env` and fill in real values.

# ── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Your Neon connection string. Use the DIRECT (non-pooled) endpoint for
# `prisma db push` / migrations; the pooled endpoint also works at runtime.
# Example: postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://user:password@host.neon.tech/neondb?sslmode=require"

# ── Dashboard ────────────────────────────────────────────────────────────────
# Password for /dashboard (leads admin). Use a strong secret.
DASHBOARD_PASSWORD="change-me-to-a-strong-password"
